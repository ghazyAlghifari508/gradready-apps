# GradReady — Environment Variables Template
# Copy this file to .env.local and fill in your own values.

# ─── Database ───────────────────────────────────────────
# PostgreSQL connection string from Supabase (Transaction mode / PgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (used for Prisma migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Better Auth ─────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET="your-random-secret-here"

# The base URL of your app (e.g. http://localhost:3000 for local dev)
BETTER_AUTH_URL="http://localhost:3000"

# ─── AI / NVIDIA NIM ─────────────────────────────────────
# Get your key from https://build.nvidia.com/
NVIDIA_NIM_API_KEY="nvapi-..."

# Your public app URL, used for payment callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Midtrans Sandbox ────────────────────────────────────
# For local webhook testing, expose /api/billing/webhook with ngrok or cloudflared.
MIDTRANS_SERVER_KEY="SB-Mid-server-XXXXXXXXXXXXXXXX"
MIDTRANS_CLIENT_KEY="SB-Mid-client-XXXXXXXXXXXXXXXX"
MIDTRANS_MERCHANT_ID="GXXXXXXXXX"
MIDTRANS_IS_PRODUCTION="false"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-XXXXXXXXXXXXXXXX"

# ─── (Optional) Storage ──────────────────────────────────
# Supabase Storage for CV file uploads
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
